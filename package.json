{
  "name": "@printezisn/solidboy",
  "type": "module",
  "version": "0.1.0",
  "author": {
    "name": "Nikos Printezis",
    "url": "https://printezisn.github.io/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/printezisn/solidboy"
  },
  "homepage": "https://printezisn.github.io/",
  "files": [
    "dist"
  ],
  "module": "./dist/index.js",
  "main": "./dist/index.umd.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    },
    "./templates": {
      "import": "./dist/templates.js",
      "require": "./dist/templates.cjs"
    },
    "./style.css": {
      "import": "./dist/style.css",
      "require": "./dist/style.css"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build:wasm:dev": "wasm-pack build ./emulator --target bundler && pnpm i --force ./emulator/pkg",
    "build:wasm:prod": "wasm-pack build ./emulator --target bundler --release && pnpm i --force ./emulator/pkg",
    "build:prod": "pnpm build:wasm:prod && vite build",
    "format": "prettier ./src --write",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "start:dev": "pnpm build:wasm:dev && vite --port 3000",
    "start:prod": "pnpm build:wasm:prod && vite preview --port 4000",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "emulator-lib": "link:emulator/pkg",
    "eslint": "^10.1.0",
    "feather-icons": "^4.29.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "vite": "^8.0.1",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-wasm": "^3.6.0"
  },
  "dependencies": {
    "husky": "^9.1.7",
    "solidboy-emulator": "link:emulator/pkg"
  }
}
